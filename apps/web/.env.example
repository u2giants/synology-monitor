# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# AI — OpenRouter is the primary provider; OPENAI_API_KEY is a fallback
OPENROUTER_API_KEY=your_openrouter_api_key
OPENAI_API_KEY=your_openai_api_key
OPENAI_CHAT_MODEL=gpt-4o

# Default model for issue detection, extraction, and clustering (via OpenRouter).
# Overridden per-user in Settings → AI Models. Falls back to minimax/minimax-m2.7 if unset.
MINIMAX_MODEL=minimax/minimax-m2.7

# Optional. Signs approval tokens for one-off NAS actions.
# Falls back to OPENROUTER_API_KEY / OPENAI_API_KEY if unset.
COPILOT_ACTION_SIGNING_KEY=replace_with_a_random_secret
COPILOT_ADMIN_EMAILS=admin@example.com,ops@example.com

# Issue worker
# inline = request path drains issue jobs
# background = dedicated worker endpoint/loop drains issue jobs
ISSUE_WORKER_MODE=inline
RUN_ISSUE_WORKER=false
ISSUE_WORKER_TOKEN=replace_with_a_random_secret
ISSUE_WORKER_INTERVAL_MS=3000
ISSUE_WORKER_BATCH_LIMIT=10

# Scheduled analysis cron (GET /api/analysis/cron?secret=<value>)
# Must match the secret configured in the Coolify scheduled task.
CRON_SECRET=replace_with_a_random_secret

# NAS API — three-tier HTTP shell execution (used by issue agent)
# URL = Tailscale IP of each NAS + the NAS_API_PORT set in the NAS .env
# SECRET and SIGNING_KEY must match NAS_API_SECRET and NAS_API_APPROVAL_SIGNING_KEY in each NAS .env
NAS_EDGE1_API_URL=http://100.x.x.x:7734
NAS_EDGE1_API_SECRET=replace_with_nas_api_secret
NAS_EDGE1_API_SIGNING_KEY=replace_with_nas_api_signing_key

NAS_EDGE2_API_URL=http://100.x.x.x:7734
NAS_EDGE2_API_SECRET=replace_with_nas_api_secret
NAS_EDGE2_API_SIGNING_KEY=replace_with_nas_api_signing_key

# Push Notifications (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
