# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://ryltkzzernhwnojzouyb.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# OpenAI NAS copilot
OPENAI_API_KEY=your_openai_api_key
