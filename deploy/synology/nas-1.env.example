NAS_ID=4f1d7e2a-7d5d-4d5f-8b55-0f8efb0d1001
NAS_NAME=Synology NAS 1

DSM_URL=https://localhost:5001
# These are DSM API credentials used by the agent itself.
# They do not need to match the SSH account you use to administer the NAS.
DSM_USERNAME=replace_me
DSM_PASSWORD=replace_me
DSM_INSECURE_SKIP_VERIFY=true

SUPABASE_URL=https://qnjimovrsaacneqkggsn.supabase.co
SUPABASE_SERVICE_KEY=replace_me
AGENT_IMAGE_TAG=latest

TZ=UTC
LOG_DIR=/host/log
EXTRA_LOG_FILES=
# Watch specific shares for Container Manager compatibility
# Include @synologydrive for ShareSync monitoring
# Container mounts shares to /host/shares/<name>
WATCH_PATHS=/host/shares/files,/host/shares/styleguides,/host/shares/users,/host/shares/homes,/host/shares/Coldlion,/host/shares/Photography,/host/shares/freelancers,/host/shares/mgmt,/host/shares/mac,/host/shares/oldStyleguides,/host/shares/@synologydrive,/host/shares/@SynologyDriveShareSync
CHECKSUM_PATHS=/host/shares/files,/host/shares/styleguides,/host/shares/users
MAX_INOTIFY_DIRS=5000
DATA_DIR=/app/data
INFRA_INTERVAL=2m

# ── NAS API — three-tier shell execution service ──────────────────────────────
# These values MUST match the NAS_EDGE1_API_* vars in the web app (Coolify).
NAS_API_SECRET=f611b43668599521c71421bc96deae0b7920f91cd0381888a8746238526ef1a4
NAS_API_APPROVAL_SIGNING_KEY=fcd42b9f33be9dfdedbf5614a92e263ca474a6a14284927c95ce695699f9f677
NAS_API_PORT=7734
