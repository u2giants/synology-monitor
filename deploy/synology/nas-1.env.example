NAS_ID=4f1d7e2a-7d5d-4d5f-8b55-0f8efb0d1001
NAS_NAME=Synology NAS 1

DSM_URL=https://localhost:5001
# These are DSM API credentials used by the agent itself.
# They do not need to match the SSH account you use to administer the NAS.
DSM_USERNAME=replace_me
DSM_PASSWORD=replace_me
DSM_INSECURE_SKIP_VERIFY=true

SUPABASE_URL=https://ryltkzzernhwnojzouyb.supabase.co
SUPABASE_SERVICE_KEY=replace_me
AGENT_IMAGE_TAG=latest

TZ=UTC
LOG_DIR=/host/log
EXTRA_LOG_FILES=
# Watch specific shares for Container Manager compatibility
# Include @synologydrive for ShareSync monitoring
WATCH_PATHS=/host/volume1/files,/host/volume1/styleguides,/host/volume1/users,/host/volume1/homes,/host/volume1/Coldlion,/host/volume1/Photography,/host/volume1/freelancers,/host/volume1/mgmt,/host/volume1/mac,/host/volume1/oldStyleguides,/host/volume1/@synologydrive,/host/volume1/@SynologyDriveShareSync
CHECKSUM_PATHS=/host/volume1/files,/host/volume1/styleguides,/host/volume1/users
MAX_INOTIFY_DIRS=5000
DATA_DIR=/app/data
