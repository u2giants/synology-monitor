# Copy to .env on each Synology NAS and customize the NAS-specific values.

NAS_ID=4f1d7e2a-7d5d-4d5f-8b55-0f8efb0d1001
NAS_NAME=Synology NAS 1

DSM_URL=https://localhost:5001
# These are DSM API credentials used by the agent itself.
# They do not need to match the SSH account you use to administer the NAS.
DSM_USERNAME=your_dsm_username
DSM_PASSWORD=your_dsm_password
DSM_INSECURE_SKIP_VERIFY=true

SUPABASE_URL=https://qnjimovrsaacneqkggsn.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
AGENT_IMAGE_TAG=latest

TZ=UTC
LOG_DIR=/host/log
# Optional extra log files in "path|source" format, comma-separated.
# Example:
# EXTRA_LOG_FILES=/host/packages/SynologyDrive/target/var/some.log|drive_admin
EXTRA_LOG_FILES=
WATCH_PATHS=/host/volume1
CHECKSUM_PATHS=/host/volume1
MAX_INOTIFY_DIRS=5000
DATA_DIR=/app/data

METRICS_INTERVAL=30s
STORAGE_INTERVAL=60s
LOG_INTERVAL=10s
DOCKER_INTERVAL=30s
SECURITY_INTERVAL=15m

# Resource attribution collectors (added for I/O spike diagnosis)
# Lower these if you see bursty I/O and want finer-grained samples.
PROCESS_INTERVAL=15s       # per-process CPU/mem/disk I/O sampling
DISKSTATS_INTERVAL=15s     # per-disk IOPS/latency/utilisation
CONNECTIONS_INTERVAL=30s   # active network connection enumeration

BATCH_SIZE=100
FLUSH_TIMEOUT=30s
MAX_WAL_SIZE_MB=100

# ── NAS API (three-tier shell execution service) ──────────────────────────────
# Random secret shared between the web app and this NAS. Use: openssl rand -hex 32
NAS_API_SECRET=change_me_use_openssl_rand_hex_32
# Separate HMAC key used to sign approval tokens for tier 2/3 commands.
NAS_API_APPROVAL_SIGNING_KEY=change_me_use_openssl_rand_hex_32
# Port the NAS API listens on (default 7734). Must be reachable from the web app.
NAS_API_PORT=7734
