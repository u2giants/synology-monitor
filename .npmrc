# Use a flat, npm-like node_modules layout instead of pnpm's symlinked virtual
# store. Next.js/webpack fails to resolve a dependency when pnpm gives it a
# peer-specialized path (e.g. `openai@6.x_ws@8.x`, introduced once @google/genai
# pulled `ws` into the tree) — the symlink resolves under Node but not under the
# web image's webpack build. Hoisting keeps every dependency resolvable from any
# workspace package by walk-up, which is what the web build expects.
#
# Scope: only affects installs run from the repo root (web image build, CI, local
# dev). The nas-mcp image builds with `context: ./apps/nas-mcp`, so it does NOT
# see this file.
node-linker=hoisted
